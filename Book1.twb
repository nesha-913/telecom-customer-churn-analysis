      <column-instance column='[InternetService]' derivation='None' name='[none:InternetService:nk]' pivot='key' type='nominal' />
      <column-instance column='[PaymentMethod]' derivation='None' name='[none:PaymentMethod:nk]' pivot='key' type='nominal' />
      <column-instance column='[TechSupport]' derivation='None' name='[none:TechSupport:nk]' pivot='key' type='nominal' />
      <layout dim-ordering='alphabetic' measure-ordering='alphabetic' show-structure='true' />
      <style>
        <style-rule element='mark'>
          <encoding attr='color' field='[none:Contract:nk]' type='palette'>
            <map to='#59a14f'>
              <bucket>&quot;Month-to-month&quot;</bucket>
            </map>
            <map to='#e15759'>
              <bucket>&quot;Two year&quot;</bucket>
            </map>
            <map to='#f28e2b'>
              <bucket>&quot;One year&quot;</bucket>
            </map>
          </encoding>
          <encoding attr='color' field='[none:InternetService:nk]' type='palette'>
            <map to='#b07aa1'>
              <bucket>&quot;Fiber optic&quot;</bucket>
            </map>
            <map to='#e15759'>
              <bucket>&quot;No&quot;</bucket>
            </map>
            <map to='#f28e2b'>
              <bucket>&quot;DSL&quot;</bucket>
            </map>
          </encoding>
          <encoding attr='color' field='[none:TechSupport:nk]' type='palette'>
            <map to='#4e79a7'>
              <bucket>&quot;No&quot;</bucket>
            </map>
            <map to='#e15759'>
              <bucket>&quot;No internet service&quot;</bucket>
            </map>
            <map to='#f28e2b'>
              <bucket>&quot;Yes&quot;</bucket>
            </map>
          </encoding>
          <encoding attr='color' field='[none:PaymentMethod:nk]' type='palette'>
            <map to='#4e79a7'>
              <bucket>&quot;Electronic check&quot;</bucket>
            </map>
            <map to='#76b7b2'>
              <bucket>&quot;Credit card (automatic)&quot;</bucket>
            </map>
            <map to='#e15759'>
              <bucket>&quot;Bank transfer (automatic)&quot;</bucket>
            </map>
            <map to='#f28e2b'>
              <bucket>&quot;Mailed check&quot;</bucket>
            </map>
          </encoding>
        </style-rule>
      </style>
      <semantic-values>
        <semantic-value key='[Country].[Name]' value='&quot;United States&quot;' />
      </semantic-values>
