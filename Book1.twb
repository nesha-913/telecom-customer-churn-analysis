      <aliases enabled='yes' />
      <column caption='Churn Rate' datatype='real' default-format='p0.00%' name='[Calculation_0616024399224833]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [Churn] = &quot;Yes&quot; THEN 1 ELSE 0 END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([customerID])' />
      </column>
      <column caption='Risk Segment' datatype='string' name='[Calculation_0616024408190978]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Contract] = &quot;Month-to-month&quot;&#13;&#10;AND [tenure] &lt; 12&#13;&#10;AND [MonthlyCharges] &gt; 64.80&#13;&#10;THEN &quot;Potential High Risk&quot;&#13;&#10;ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Blank' datatype='string' name='[Calculation_0616024409866243]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;&quot;' />
      </column>
